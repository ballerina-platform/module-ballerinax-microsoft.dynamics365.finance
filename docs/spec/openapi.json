{
  "openapi": "3.0.3",
  "info": {
    "title": "Microsoft Dynamics 365 Finance and Operations",
    "description": "Ballerina connector for a curated subset of the Microsoft Dynamics 365 Finance and Operations OData REST API. Exposes the master data and transactional entities most commonly used in demo scenarios: customers, vendors, released products, sales and purchase orders, general-ledger journal entries, and reference data.",
    "version": "1.0.0",
    "license": {
      "name": "Apache-2.0",
      "url": "https://www.apache.org/licenses/LICENSE-2.0"
    },
    "contact": {
      "name": "Ballerina",
      "url": "https://ballerina.io"
    }
  },
  "servers": [
    {
      "url": "https://{tenant}.operations.dynamics.com/data",
      "description": "Dynamics 365 Finance and Operations tenant",
      "variables": {
        "tenant": {
          "default": "your-org",
          "description": "Tenant-specific subdomain (e.g. contoso, contoso-test)"
        }
      }
    }
  ],
  "security": [
    { "oAuth2": [] },
    { "bearerAuth": [] }
  ],
  "tags": [
    { "name": "Customers", "description": "Customer master data (CustomersV3 entity set)" },
    { "name": "Vendors", "description": "Vendor master data (VendorsV2 entity set)" },
    { "name": "Products", "description": "Released product master data (ReleasedProductsV2 entity set)" },
    { "name": "Sales Orders", "description": "Sales order headers (SalesOrderHeadersV2 entity set)" },
    { "name": "Purchase Orders", "description": "Purchase order headers (PurchaseOrderHeadersV2 entity set)" },
    { "name": "General Ledger", "description": "General journal entries and ledger journals" },
    { "name": "Exchange Rates", "description": "Currency exchange rates" },
    { "name": "Reference Data", "description": "Lookup data such as customer groups" }
  ],
  "paths": {
    "/CustomersV3": {
      "get": {
        "tags": ["Customers"],
        "summary": "List customers",
        "description": "Returns a page of customer records. Supports standard OData query options and the D365 F&O `cross-company` flag to query across legal entities.",
        "operationId": "listCustomers",
        "parameters": [
          { "$ref": "#/components/parameters/select" },
          { "$ref": "#/components/parameters/filter" },
          { "$ref": "#/components/parameters/top" },
          { "$ref": "#/components/parameters/skip" },
          { "$ref": "#/components/parameters/orderBy" },
          { "$ref": "#/components/parameters/expand" },
          { "$ref": "#/components/parameters/count" },
          { "$ref": "#/components/parameters/crossCompany" }
        ],
        "responses": {
          "200": {
            "description": "Customer collection",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CustomersV3Collection" }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ODataError" }
        }
      },
      "post": {
        "tags": ["Customers"],
        "summary": "Create customer",
        "description": "Creates a new customer in the specified legal entity (`dataAreaId`).",
        "operationId": "createCustomer",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CustomerV3" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Customer created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CustomerV3" }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ODataError" }
        }
      }
    },
    "/CustomersV3(dataAreaId='{dataAreaId}',CustomerAccount='{customerAccount}')": {
      "parameters": [
        { "$ref": "#/components/parameters/dataAreaId" },
        { "$ref": "#/components/parameters/customerAccount" }
      ],
      "get": {
        "tags": ["Customers"],
        "summary": "Get customer",
        "description": "Returns a single customer identified by the composite key (`dataAreaId`, `CustomerAccount`).",
        "operationId": "getCustomer",
        "parameters": [
          { "$ref": "#/components/parameters/select" },
          { "$ref": "#/components/parameters/expand" }
        ],
        "responses": {
          "200": {
            "description": "Customer record",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CustomerV3" }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ODataError" }
        }
      },
      "patch": {
        "tags": ["Customers"],
        "summary": "Update customer",
        "description": "Partially updates a customer. Only fields supplied in the request body are modified. The `If-Match` header enforces optimistic concurrency when set to the record's `@odata.etag`.",
        "operationId": "updateCustomer",
        "parameters": [
          { "$ref": "#/components/parameters/ifMatch" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CustomerV3" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Customer updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CustomerV3" }
              }
            }
          },
          "default": { "$ref": "#/components/responses/ODataError" }
        }
      },
      "delete": {
        "tags": ["Customers"],
        "summary": "Delete customer",
        "description": "Deletes a customer. `If-Match` is honoured for optimistic concurrency.",
        "operationId": "deleteCustomer",
        "parameters": [
          { "$ref": "#/components/parameters/ifMatch" }
        ],
        "responses": {
          "204": { "description": "Customer deleted" },
          "default": { "$ref": "#/components/responses/ODataError" }
        }
      }
    },
